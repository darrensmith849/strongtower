# Strong Tower — environment variables

# Resend (email delivery) — get a key at https://resend.com
# The site stays fully functional without this; submissions are logged to the
# server console in development and the API returns a friendly response so
# nothing crashes when these are absent.
RESEND_API_KEY=

# The verified sender address for Resend (e.g. "Strong Tower <hello@strongtower.org>")
MAIL_FROM=

# Destination inboxes for each form
MAIL_TO_PILOT=
MAIL_TO_SUPPORT=
MAIL_TO_CONTACT=
