# Strong Tower — environment variables
#
# All of the variables below are OPTIONAL. The site builds, deploys, and
# accepts form submissions without any of them — submissions are simply
# logged to the server console until you configure a destination.
#
# Configure one or both:
#   - Resend (email delivery)
#   - Google Sheets (row-by-row persistence)
#
# If both are configured, every submission is both emailed and saved.

# ---------- Resend (email delivery) ----------
# Get an API key at https://resend.com
RESEND_API_KEY=

# The verified sender address for Resend
# Example: "Strong Tower <hello@strongtower.org>"
MAIL_FROM=

# Destination inboxes for each form
MAIL_TO_PILOT=
MAIL_TO_SUPPORT=
MAIL_TO_CONTACT=

# ---------- Google Sheets (row persistence) ----------
# Service account credentials from a Google Cloud project with the
# Sheets API enabled. Share the target spreadsheet with the service
# account email (as Editor). See README for full setup steps.

# Example: my-service-account@my-project.iam.gserviceaccount.com
GOOGLE_SHEETS_CLIENT_EMAIL=

# The full PEM private key. In .env files, escape real newlines as \n
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_PRIVATE_KEY=

# The ID from the spreadsheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Tab names inside the spreadsheet. These defaults match the README setup.
GOOGLE_SHEETS_PILOT_SHEET_NAME=Pilot Waitlist
GOOGLE_SHEETS_SUPPORT_SHEET_NAME=Support Interest
GOOGLE_SHEETS_CONTACT_SHEET_NAME=Contact Messages
